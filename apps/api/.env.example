# ─── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── SUPABASE (get from supabase.com → Project Settings → API) ───
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ───
JWT_ACCESS_SECRET=generate_a_random_64_char_string_here
JWT_REFRESH_SECRET=generate_a_different_random_64_char_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── GROQ AI (get from console.groq.com → API Keys) ───
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── WHATSAPP (Local-only mode uses whatsapp-web.js with QR scan and .wwebjs_auth session) ───
# Set to false on free cloud hosts (Koyeb/Render/etc.) to disable whatsapp-web.js startup.
WHATSAPP_ENABLED=true
# These Meta Cloud API vars are optional for future migration.
WHATSAPP_TOKEN=optional_for_meta_cloud_api
WHATSAPP_PHONE_ID=optional_for_meta_cloud_api
WHATSAPP_VERIFY_TOKEN=optional_for_meta_cloud_api

# ─── REDIS (local Docker — no changes needed for development) ───
REDIS_URL=redis://localhost:6379

# ─── FRONTEND URL (for CORS) ───
FRONTEND_URL=http://localhost:5173

# ─── LOCAL HARDENING ──────────────────────────────────
CLINIC_TIMEZONE=Asia/Kolkata
AUTH_RATE_LIMIT_PER_15_MIN=25
API_RATE_LIMIT_PER_MIN=240
PUBLIC_RATE_LIMIT_PER_MIN=60
